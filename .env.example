# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key (required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Fund configuration
FUND_NAME=My Investment Fund

# OpenAI model to use (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Analysis period for historical data (optional, defaults to 1y)
# Options: 1mo, 3mo, 6mo, 1y, 2y, 5y
DATA_PERIOD=1y

# Risk-free rate for Sharpe ratio calculation (optional, defaults to 0.02)
RISK_FREE_RATE=0.02
